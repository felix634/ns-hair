---
import Layout from '../layouts/Layout.astro';

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Főoldal", "item": "https://nagysandorhair.hu/" },
    { "@type": "ListItem", "position": 2, "name": "Impresszum", "item": "https://nagysandorhair.hu/impresszum" }
  ]
};
---

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

<Layout title="Impresszum – Nagy Sándor Hair & Beauty">
    <!-- Header -->
    <header class="border-b border-white/5 relative z-30">
        <div class="max-w-6xl mx-auto px-4 py-6 flex items-center justify-between">
            <a href="/" class="flex items-center gap-3 group">
                <img src="/logo.webp" alt="Nagy Sándor Hair & Beauty" class="h-10 w-auto" width="666" height="375" />
                <div class="hidden sm:block">
                    <span class="text-white font-serif text-lg font-semibold tracking-wide">NS</span>
                    <span class="text-ns-gold text-xs block -mt-1 tracking-[0.2em] uppercase font-light">Hair & Beauty</span>
                </div>
            </a>
            <a href="/" class="text-gray-400 hover:text-ns-gold transition-colors duration-300 text-sm uppercase tracking-wider border-b border-gray-700 hover:border-ns-gold pb-1">
                ← Vissza a főoldalra
            </a>
        </div>
    </header>

    <main class="max-w-3xl mx-auto px-4 py-16 md:py-24 relative z-20">
        <h1 class="text-4xl md:text-5xl font-serif font-bold text-white mb-4 uppercase">Impresszum</h1>
        <div class="accent-line mb-10 mx-0"></div>

        <div class="bg-gradient-to-b from-[#1a1a1a] to-[#0a0a0a] border border-white/10 shadow-2xl rounded-2xl p-6 md:p-10 space-y-8 relative">

            <section>
                <h2 class="text-ns-gold text-xs font-bold uppercase tracking-[0.2em] mb-4">Szolgáltató</h2>
                <dl class="space-y-3 text-gray-300">
                    <div class="flex flex-col sm:flex-row sm:gap-4">
                        <dt class="text-gray-500 text-sm w-full sm:w-48 shrink-0">Cégnév:</dt>
                        <dd class="font-medium">NS HAIR Kft.</dd>
                    </div>
                    <div class="flex flex-col sm:flex-row sm:gap-4">
                        <dt class="text-gray-500 text-sm w-full sm:w-48 shrink-0">Márkanév:</dt>
                        <dd>Nagy Sándor Hair & Beauty</dd>
                    </div>
                    <div class="flex flex-col sm:flex-row sm:gap-4">
                        <dt class="text-gray-500 text-sm w-full sm:w-48 shrink-0">Székhely:</dt>
                        <dd>6720 Szeged, Horváth Mihály u. 9.</dd>
                    </div>
                    <div class="flex flex-col sm:flex-row sm:gap-4">
                        <dt class="text-gray-500 text-sm w-full sm:w-48 shrink-0">Adószám:</dt>
                        <dd>13578848-1-06</dd>
                    </div>
                    <div class="flex flex-col sm:flex-row sm:gap-4">
                        <dt class="text-gray-500 text-sm w-full sm:w-48 shrink-0">Cégjegyzékszám:</dt>
                        <dd>06-09-010149</dd>
                    </div>
                    <div class="flex flex-col sm:flex-row sm:gap-4">
                        <dt class="text-gray-500 text-sm w-full sm:w-48 shrink-0">Nyilvántartó hatóság:</dt>
                        <dd>Szegedi Törvényszék Cégbírósága</dd>
                    </div>
                </dl>
            </section>

            <hr class="border-white/5" />

            <section>
                <h2 class="text-ns-gold text-xs font-bold uppercase tracking-[0.2em] mb-4">Kapcsolat</h2>
                <dl class="space-y-3 text-gray-300">
                    <div class="flex flex-col sm:flex-row sm:gap-4">
                        <dt class="text-gray-500 text-sm w-full sm:w-48 shrink-0">Telefon:</dt>
                        <dd><a href="tel:+36305355678" class="hover:text-ns-gold transition-colors">+36 30 535 5678</a></dd>
                    </div>
                    <div class="flex flex-col sm:flex-row sm:gap-4">
                        <dt class="text-gray-500 text-sm w-full sm:w-48 shrink-0">Email:</dt>
                        <dd><a href="mailto:nagysandorhair@gmail.com" class="hover:text-ns-gold transition-colors break-all">nagysandorhair@gmail.com</a></dd>
                    </div>
                </dl>
            </section>

            <hr class="border-white/5" />

            <section>
                <h2 class="text-ns-gold text-xs font-bold uppercase tracking-[0.2em] mb-4">Tárhelyszolgáltató</h2>
                <dl class="space-y-3 text-gray-300">
                    <div class="flex flex-col sm:flex-row sm:gap-4">
                        <dt class="text-gray-500 text-sm w-full sm:w-48 shrink-0">Név:</dt>
                        <dd>Netlify, Inc.</dd>
                    </div>
                    <div class="flex flex-col sm:flex-row sm:gap-4">
                        <dt class="text-gray-500 text-sm w-full sm:w-48 shrink-0">Cím:</dt>
                        <dd>512 2nd Street, Suite 200, San Francisco, CA 94107, Amerikai Egyesült Államok</dd>
                    </div>
                    <div class="flex flex-col sm:flex-row sm:gap-4">
                        <dt class="text-gray-500 text-sm w-full sm:w-48 shrink-0">Email:</dt>
                        <dd><a href="mailto:support@netlify.com" class="hover:text-ns-gold transition-colors">support@netlify.com</a></dd>
                    </div>
                </dl>
            </section>

            <hr class="border-white/5" />

            <section>
                <h2 class="text-ns-gold text-xs font-bold uppercase tracking-[0.2em] mb-4">Szerzői jog</h2>
                <p class="text-gray-400 text-sm leading-relaxed">
                    A weboldal teljes tartalma (szövegek, képek, grafikai elemek, logó) az NS HAIR Kft. tulajdonát képezi. A tartalmak bármilyen felhasználása, másolása, terjesztése – részben vagy egészben – csak a szolgáltató előzetes írásbeli engedélyével lehetséges.
                </p>
            </section>

        </div>

        <p class="text-gray-600 text-xs mt-8">
            További információ: <a href="/adatkezelesi-tajekoztato" class="text-ns-gold hover:underline">Adatkezelési tájékoztató</a>
        </p>
    </main>

    <!-- Footer -->
    <footer class="border-t border-white/5 relative z-20 mt-20">
        <div class="max-w-6xl mx-auto px-4 py-8">
            <div class="flex flex-col md:flex-row items-center justify-between gap-4">
                <p class="text-gray-700 text-xs">© {new Date().getFullYear()} NS HAIR Kft. Minden jog fenntartva.</p>
                <div class="flex items-center gap-4 text-xs">
                    <a href="/impresszum" class="text-gray-500 hover:text-ns-gold transition-colors">Impresszum</a>
                    <a href="/adatkezelesi-tajekoztato" class="text-gray-500 hover:text-ns-gold transition-colors">Adatkezelési tájékoztató</a>
                </div>
            </div>
        </div>
    </footer>
</Layout>
