---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.jsx';
import HeroTitle from '../components/HeroTitle.jsx';
import FadeIn from '../components/FadeIn.jsx';

import GSAPAnimations from '../components/GSAPAnimations.jsx';

const galleryItems = [
  { img: 'munka1.png', text: 'Selymes Egyenes Balayage' },
  { img: 'munka2.png', text: 'Csokoládé Hullámok' },
  { img: 'munka3.png', text: 'Extrém Fonás' },
  { img: 'munka4.png', text: 'Alkalmi Feltűzés' },
  { img: 'munka5.png', text: 'Hamvas Szőke' },
  { img: 'munka6.png', text: 'Vivid Color Ombre' }
];

const stats = [
  { number: 10, suffix: '+', label: 'Év Tapasztalat' },
  { number: 5000, suffix: '+', label: 'Elégedett Vendég' },
  { number: 150, suffix: '+', label: 'Technika' },
  { number: 98, suffix: '%', label: 'Visszatérő Vendég' },
];
---

<Layout title="Nagy Sándor Hair & Beauty – Prémium Fodrászat Szegeden">
    <Navbar client:load />
    <GSAPAnimations client:load />

    <main>
        <!-- ===== HERO ===== -->
        <section id="hero-section" class="min-h-screen flex items-center justify-center text-center px-4 pt-20 overflow-hidden relative">
            <!-- Radial gradient overlay -->
            <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_0%,rgba(0,0,0,0.7)_70%)] z-0"></div>
            
            <div id="hero-content" class="max-w-5xl mx-auto space-y-6 relative z-10">
                <div class="mb-10">
                    <HeroTitle client:load />
                </div>
                <FadeIn client:load delay={1.2} direction="up">
                    <p class="text-lg md:text-xl text-gray-400 max-w-2xl mx-auto mt-6 font-light leading-relaxed">
                        Professzionális hajvágás és stílustanácsadás <span class="text-ns-gold">Szegeden</span>.<br class="hidden md:block" />
                        Ahol a stílus prémium minőséggel találkozik.
                    </p>
                    <div class="pt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
                        <a href="#idopont" class="group relative bg-gradient-to-r from-ns-red to-ns-red-light text-white font-bold py-4 px-8 rounded-full transition-all duration-500 uppercase tracking-wide text-base md:text-lg shadow-lg shadow-ns-red/20 hover:shadow-ns-red/40 hover:-translate-y-1 inline-block overflow-hidden w-full sm:w-auto text-center">
                            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:animate-shimmer"></div>
                            <span class="relative">Időpontfoglalás</span>
                        </a>
                        <a href="#munkaink" class="text-gray-400 hover:text-ns-gold transition-colors duration-300 font-medium uppercase tracking-wider text-sm border-b border-gray-700 hover:border-ns-gold pb-1">
                            Munkáink megtekintése →
                        </a>
                    </div>
                </FadeIn>
            </div>

            <!-- Scroll indicator -->
            <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10">
                <FadeIn client:load delay={2} direction="up">
                    <div class="flex flex-col items-center gap-2 text-gray-600">
                        <span class="text-[10px] uppercase tracking-[0.3em]">Görgess</span>
                        <div class="w-[1px] h-8 bg-gradient-to-b from-ns-gold/50 to-transparent"></div>
                    </div>
                </FadeIn>
            </div>
        </section>

        <!-- Divider -->
        <div class="section-divider"></div>

        <!-- ===== RÓLUNK + STATS ===== -->
        <section id="rolunk" class="gsap-section py-16 md:py-28 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-ns-gold/5 rounded-full blur-[150px] pointer-events-none"></div>

            <div class="max-w-5xl mx-auto px-4">
                <div class="text-center mb-10 md:mb-16">
                    <h2 class="gsap-heading text-3xl md:text-5xl font-serif font-bold text-white mb-4 uppercase">Rólunk</h2>
                    <div class="accent-line mb-6"></div>
                    <p class="gsap-subtext text-lg text-gray-400 leading-relaxed max-w-3xl mx-auto">
                        Üdvözöllek a <span class="text-white font-semibold">Nagy Sándor Hair & Beauty</span> szalonban! Célunk, hogy minden vendégünk magabiztosan és elégedetten távozzon. Modern környezetben, a legújabb technikákkal és <span class="text-ns-gold">prémium anyagokkal</span> dolgozunk, hogy megtaláljuk a hozzád legjobban illő stílust.
                    </p>
                </div>

                <!-- Stats Grid -->
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8">
                    {stats.map((stat) => (
                        <div class="gsap-content text-center p-4 md:p-6 rounded-2xl glass hover:border-ns-gold/20 transition-all duration-500 group">
                            <div class="text-3xl md:text-5xl font-bold text-white mb-2 font-serif group-hover:text-ns-gold transition-colors duration-300">
                                <span class="stat-number" data-target={stat.number}>0</span><span class="text-ns-gold">{stat.suffix}</span>
                            </div>
                            <div class="text-xs md:text-sm text-gray-500 uppercase tracking-widest font-medium">{stat.label}</div>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- Divider -->
        <div class="section-divider"></div>

        <!-- ===== SZOLGÁLTATÁSOK & ÁRAK ===== -->
        <section id="arak" class="gsap-section py-16 md:py-28 overflow-hidden relative">
            <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-ns-red/5 rounded-full blur-[150px] -z-10 pointer-events-none"></div>

            <div class="max-w-6xl mx-auto px-4">
                <div class="text-center mb-10 md:mb-16">
                    <h2 class="gsap-heading text-3xl md:text-5xl font-serif font-bold text-white mb-4 uppercase">
                        Szolgáltatások <span class="text-ns-gold">&</span> Árak
                    </h2>
                    <div class="accent-line mb-6"></div>
                    <p class="gsap-subtext text-gray-400 max-w-2xl mx-auto">
                        Minden vendégünk egyedi – az árak a haj hosszától, állapotától és az igényelt technikától függően változnak.
                    </p>
                </div>

                <!-- Szolgáltatás kártyák -->
                <FadeIn client:visible delay={0.2} direction="up">
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5 mb-10 md:mb-14">
                        <!-- Vágás -->
                        <div class="glass p-6 rounded-2xl text-center group hover:border-ns-gold/20 transition-all duration-500">
                            <div class="w-14 h-14 mx-auto mb-4 bg-ns-red/10 rounded-xl flex items-center justify-center group-hover:bg-ns-red/20 transition-colors duration-300">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-ns-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.121 14.121L19 19m-7-7l7-7m-7 7l-2.879 2.879M12 12L9.121 9.121m0 5.758a3 3 0 10-4.243 4.243 3 3 0 004.243-4.243zm0-5.758a3 3 0 10-4.243-4.243 3 3 0 004.243 4.243z" /></svg>
                            </div>
                            <h3 class="text-white font-bold text-lg mb-2 uppercase tracking-wide">Hajvágás</h3>
                            <p class="text-gray-300 text-sm leading-relaxed">Női & férfi vágás, szárítás, formázás – stílusod, a Te szabályaid szerint.</p>
                        </div>
                        <!-- Festés -->
                        <div class="glass p-6 rounded-2xl text-center group hover:border-ns-gold/20 transition-all duration-500">
                            <div class="w-14 h-14 mx-auto mb-4 bg-ns-red/10 rounded-xl flex items-center justify-center group-hover:bg-ns-red/20 transition-colors duration-300">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-ns-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg>
                            </div>
                            <h3 class="text-white font-bold text-lg mb-2 uppercase tracking-wide">Festés & Színezés</h3>
                            <p class="text-gray-300 text-sm leading-relaxed">Tőfestés, teljes festés, szőkítés, vivid színek – a lehető legjobb anyagokkal.</p>
                        </div>
                        <!-- Balayage -->
                        <div class="glass p-6 rounded-2xl text-center group hover:border-ns-gold/20 transition-all duration-500">
                            <div class="w-14 h-14 mx-auto mb-4 bg-ns-red/10 rounded-xl flex items-center justify-center group-hover:bg-ns-red/20 transition-colors duration-300">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-ns-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg>
                            </div>
                            <h3 class="text-white font-bold text-lg mb-2 uppercase tracking-wide">Balayage & Ombre</h3>
                            <p class="text-gray-300 text-sm leading-relaxed">Természetes színátmenetek, dimenziós hatás – kézzel festett technikával.</p>
                        </div>
                        <!-- Kezelések -->
                        <div class="glass p-6 rounded-2xl text-center group hover:border-ns-gold/20 transition-all duration-500">
                            <div class="w-14 h-14 mx-auto mb-4 bg-ns-red/10 rounded-xl flex items-center justify-center group-hover:bg-ns-red/20 transition-colors duration-300">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-ns-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
                            </div>
                            <h3 class="text-white font-bold text-lg mb-2 uppercase tracking-wide">Hajkezelések</h3>
                            <p class="text-gray-300 text-sm leading-relaxed">K18, Olaplex, mélyhidratáló pakolás – a hajad egészségéért.</p>
                        </div>
                        <!-- Styling -->
                        <div class="glass p-6 rounded-2xl text-center group hover:border-ns-gold/20 transition-all duration-500">
                            <div class="w-14 h-14 mx-auto mb-4 bg-ns-red/10 rounded-xl flex items-center justify-center group-hover:bg-ns-red/20 transition-colors duration-300">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-ns-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>
                            </div>
                            <h3 class="text-white font-bold text-lg mb-2 uppercase tracking-wide">Alkalmi Styling</h3>
                            <p class="text-gray-300 text-sm leading-relaxed">Vasalás, göndörítés, feltűzés – esküvőre, rendezvényre, bármilyen alkalomra.</p>
                        </div>
                        <!-- Konzultáció -->
                        <div class="glass p-6 rounded-2xl text-center group hover:border-ns-gold/20 transition-all duration-500">
                            <div class="w-14 h-14 mx-auto mb-4 bg-ns-red/10 rounded-xl flex items-center justify-center group-hover:bg-ns-red/20 transition-colors duration-300">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-ns-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
                            </div>
                            <h3 class="text-white font-bold text-lg mb-2 uppercase tracking-wide">Konzultáció</h3>
                            <p class="text-gray-300 text-sm leading-relaxed">Ingyenes egyeztetés a kívánt stílusról – hogy biztosan azt kapd, amit elképzeltél.</p>
                        </div>
                    </div>
                </FadeIn>

                <!-- CTA: Kapcsolatfelvétel az árért -->
                <FadeIn client:visible delay={0.4} direction="up">
                    <div class="max-w-2xl mx-auto text-center bg-gradient-to-b from-[#1a1a1a] to-black rounded-3xl border border-white/10 shadow-2xl p-8 md:p-12 relative overflow-hidden">
                        <div class="absolute top-0 right-0 w-60 h-60 bg-ns-red/10 blur-[100px] rounded-full pointer-events-none"></div>
                        <div class="absolute bottom-0 left-0 w-40 h-40 bg-ns-gold/5 blur-[80px] rounded-full pointer-events-none"></div>
                        <div class="relative z-10">
                            <div class="w-16 h-16 mx-auto mb-6 bg-ns-red/10 rounded-full flex items-center justify-center">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-ns-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                            </div>
                            <h3 class="text-2xl md:text-3xl font-bold text-white mb-3 font-serif">Egyedi árajánlat</h3>
                            <p class="text-gray-400 mb-8 leading-relaxed">
                                Az árak a haj hosszától, állapotától és a választott technikától függenek.
                                <span class="text-ns-gold font-medium">Keress minket</span> és személyre szabott árajánlatot adunk – kötelezettség nélkül!
                            </p>
                            <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                                <a href="tel:+36305355678" class="group relative bg-gradient-to-r from-ns-red to-ns-red-light text-white font-bold py-4 px-8 rounded-full transition-all duration-500 uppercase tracking-wide text-base shadow-lg shadow-ns-red/20 hover:shadow-ns-red/40 hover:-translate-y-1 inline-block overflow-hidden w-full sm:w-auto text-center">
                                    <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:animate-shimmer"></div>
                                    <span class="relative">+36 30 535 5678</span>
                                </a>
                                <a href="#idopont" class="text-gray-400 hover:text-ns-gold transition-colors duration-300 font-medium uppercase tracking-wider text-sm border-b border-gray-700 hover:border-ns-gold pb-1">
                                    Kapcsolat & Időpont →
                                </a>
                            </div>
                        </div>
                    </div>
                </FadeIn>
            </div>
        </section>

        <!-- Divider -->
        <div class="section-divider"></div>

        <!-- ===== MUNKÁINK (GALÉRIA) ===== -->
        <section id="munkaink" class="gsap-section py-16 md:py-28 relative overflow-hidden">
            <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-ns-gold/5 rounded-full blur-[150px] pointer-events-none"></div>

            <div class="max-w-6xl mx-auto px-4 text-center">
                <h2 class="gsap-heading text-3xl md:text-5xl font-serif font-bold text-white mb-4 uppercase">Munkáink</h2>
                <div class="accent-line mb-6"></div>
                <p class="gsap-subtext text-gray-400 max-w-2xl mx-auto mb-10 md:mb-16">
                    Büszkék vagyunk minden egyes vendégünkre. Íme néhány kedvenc alkotásunk.
                </p>

                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5">
                    {galleryItems.map((item, i) => (
                        <div class="gallery-card aspect-square rounded-xl overflow-hidden border border-white/5 group relative cursor-pointer hover:border-ns-gold/30 transition-all duration-500">
                            <img src={`/${item.img}`} alt={item.text} class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110 group-hover:brightness-75" loading="lazy" />
                            
                            <!-- Bottom gradient overlay -->
                            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-all duration-500"></div>
                            
                            <!-- Text overlay -->
                            <div class="absolute bottom-0 left-0 right-0 p-5 translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-500">
                                <div class="flex items-center gap-2 mb-1">
                                    <div class="w-5 h-[1px] bg-ns-gold"></div>
                                    <span class="text-ns-gold text-[10px] uppercase tracking-[0.3em]">Alkotás</span>
                                </div>
                                <span class="text-white font-serif font-semibold text-lg">{item.text}</span>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- Divider -->
        <div class="section-divider"></div>

        <!-- ===== IDŐPONTFOGLALÁS & KAPCSOLAT ===== -->
        <section id="idopont" class="gsap-section py-16 md:py-28 relative z-20">
            <div class="max-w-6xl mx-auto px-4">
                <div class="text-center mb-10 md:mb-16">
                    <h2 class="gsap-heading text-3xl md:text-5xl font-serif font-bold text-white mb-4 uppercase">Időpontfoglalás</h2>
                    <div class="accent-line mb-6"></div>
                    <p class="gsap-subtext text-gray-400 max-w-2xl mx-auto">
                        Hívj minket, és foglald le időpontodat a lehető leggyorsabban!
                    </p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-stretch">
                    <!-- Contact Info Card -->
                    <div id="contact-info" class="glass p-6 md:p-10 rounded-2xl shadow-2xl text-center md:text-left flex flex-col justify-center h-full relative overflow-hidden">
                        <!-- Decorative glow -->
                        <div class="absolute -top-20 -right-20 w-40 h-40 bg-ns-red/10 rounded-full blur-[80px] pointer-events-none"></div>

                        <a href="tel:+36305355678" class="text-2xl md:text-4xl font-bold font-serif text-ns-gold hover:text-white transition-all duration-300 block mb-8 md:mb-10 group break-all md:break-normal">
                            <span class="text-sm text-gray-500 uppercase tracking-widest block mb-2 font-sans font-medium">Hívj minket</span>
                            +36 30 535 5678
                            <span class="block h-[2px] w-0 group-hover:w-full bg-gradient-to-r from-ns-gold to-ns-red transition-all duration-500 mt-2"></span>
                        </a>

                        <hr class="border-white/5 my-6" />
                        
                        <div class="space-y-6 text-left">
                            <!-- Cím -->
                            <div class="flex items-start gap-4 group">
                                <div class="bg-ns-red/10 group-hover:bg-ns-red/20 p-3 rounded-xl shrink-0 transition-colors duration-300">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-ns-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                                </div>
                                <div>
                                    <h3 class="text-sm font-bold text-white uppercase mb-1 tracking-wider">Címünk</h3>
                                    <p class="text-gray-400 text-sm">6721 Szeged, József Attila sgrt. 4-2/26</p>
                                </div>
                            </div>
                            <!-- Nyitvatartás -->
                            <div class="flex items-start gap-4 group">
                                <div class="bg-ns-red/10 group-hover:bg-ns-red/20 p-3 rounded-xl shrink-0 transition-colors duration-300">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-ns-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                                </div>
                                <div>
                                    <h3 class="text-sm font-bold text-white uppercase mb-1 tracking-wider">Nyitvatartás</h3>
                                    <p class="text-gray-400 text-sm">Hétfő – Péntek: 09:00 – 18:00</p>
                                    <p class="text-gray-400 text-sm">Szombat: 09:00 – 13:00</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Map -->
                    <div id="contact-map" class="rounded-2xl overflow-hidden border border-white/10 shadow-2xl h-full min-h-[280px] md:min-h-[400px] relative group">
                        <iframe src="https://maps.google.com/maps?q=6721+Szeged,+J%C3%B3zsef+Attila+sgrt.+4&t=&z=15&ie=UTF8&iwloc=&output=embed" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" class="absolute inset-0 w-full h-full filter grayscale-[80%] brightness-[0.6] contrast-[1.2] group-hover:grayscale-0 group-hover:brightness-100 group-hover:contrast-100 transition-all duration-700 ease-in-out" title="Nagy Sándor Hair & Beauty Térkép"></iframe>
                    </div>
                </div>
            </div>
        </section>
    </main>
    
    <!-- ===== FOOTER ===== -->
    <footer class="border-t border-white/5 relative z-20">
        <div class="max-w-6xl mx-auto px-4 py-10 md:py-16">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8">
                
                <!-- Branding -->
                <div class="text-center md:text-left">
                    <div class="flex items-center justify-center md:justify-start gap-3 mb-4">
                        <img src="/logo.png" alt="NS Logo" class="h-10 w-auto" />
                        <div>
                            <span class="text-white font-serif text-lg font-semibold">Nagy Sándor</span>
                            <span class="text-ns-gold text-xs block -mt-1 tracking-[0.15em] uppercase font-light">Hair & Beauty</span>
                        </div>
                    </div>
                    <p class="text-gray-600 text-sm max-w-xs mx-auto md:mx-0">
