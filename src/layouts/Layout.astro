---
// FONTOS: A Tailwind 4 stílusok importálása
import '../styles/app.css';
import CookieBanner from '../components/CookieBanner.jsx';

interface Props {
	title: string;
}

const { title } = Astro.props;
const siteUrl = 'https://nagysandorhair.hu';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const description = 'Nagy Sándor Hair & Beauty – Prémium fodrászat Szegeden. Professzionális hajvágás, festés, balayage, Olaplex kezelés és stílustanácsadás.';
---

<!doctype html>
<html lang="hu" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="theme-color" content="#0a0a0a" />

		<!-- Canonical -->
		<link rel="canonical" href={canonicalUrl} />

		<!-- Favicon -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={`${siteUrl}/logo.png`} />
		<meta property="og:locale" content="hu_HU" />
		<meta property="og:site_name" content="Nagy Sándor Hair & Beauty" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={`${siteUrl}/logo.png`} />

		<!-- Preconnect Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- Structured Data: Local Business -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "HairSalon",
			"name": "Nagy Sándor Hair & Beauty",
			"legalName": "NS HAIR Kft.",
			"description": description,
			"url": siteUrl,
			"telephone": "+36305355678",
			"email": "nagysandorhair@gmail.com",
			"image": `${siteUrl}/logo.png`,
			"address": {
				"@type": "PostalAddress",
				"streetAddress": "Horváth Mihály u. 9.",
				"addressLocality": "Szeged",
				"postalCode": "6720",
				"addressCountry": "HU"
			},
			"geo": {
				"@type": "GeoCoordinates",
				"latitude": 46.255128,
				"longitude": 20.150222
			},
			"openingHoursSpecification": [
				{
					"@type": "OpeningHoursSpecification",
					"dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
					"opens": "07:00",
					"closes": "19:00"
				}
			],
			"priceRange": "$$",
			"currenciesAccepted": "HUF",
			"paymentAccepted": "Cash, Credit Card",
			"areaServed": {
				"@type": "City",
				"name": "Szeged"
			}
		})} />
	</head>
	
	<body class="bg-ns-black text-ns-silver font-sans antialiased relative min-h-screen overflow-x-hidden">
		
		<!-- Fixed Background with Parallax Target -->
		<div class="fixed inset-0 w-full h-full -z-10">
			<div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/70 to-black/90 z-10"></div>
			<img id="hero-bg" src="/bg.png" alt="" class="w-full h-full object-cover" width="1280" height="720" />
		</div>

		<!-- Floating Decorative Elements -->
		<div class="fixed inset-0 pointer-events-none -z-5 overflow-hidden">
			<div class="float-element absolute top-[20%] right-[10%] w-2 h-2 rounded-full bg-ns-gold/20"></div>
			<div class="float-element absolute top-[40%] left-[5%] w-1.5 h-1.5 rounded-full bg-ns-red/15"></div>
			<div class="float-element absolute top-[60%] right-[20%] w-1 h-1 rounded-full bg-ns-gold/25"></div>
			<div class="float-element absolute top-[80%] left-[15%] w-2 h-2 rounded-full bg-ns-red/10"></div>
		</div>

		<div class="relative z-20">
			<slot />
		</div>

		<CookieBanner client:load />

	</body>
</html>