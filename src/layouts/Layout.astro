---
// FONTOS: A Tailwind 4 stílusok importálása
import '../styles/app.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="hu" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Nagy Sándor Hair & Beauty - Prémium fodrászat Szegeden. Professzionális hajvágás, festés, balayage és stílustanácsadás." />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		
		<!-- Favicon -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		
		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content="Prémium fodrászat Szegeden. Professzionális hajvágás, festés, balayage és stílustanácsadás." />
		<meta property="og:type" content="website" />
		<meta property="og:image" content="/logo.png" />
		
		<!-- Preconnect Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	
	<body class="bg-ns-black text-ns-silver font-sans antialiased relative min-h-screen overflow-x-hidden">
		
		<!-- Fixed Background with Parallax Target -->
		<div class="fixed inset-0 w-full h-full -z-10">
			<div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/70 to-black/90 z-10"></div>
			<img id="hero-bg" src="/bg.png" alt="" class="w-full h-full object-cover" />
		</div>

		<!-- Floating Decorative Elements -->
		<div class="fixed inset-0 pointer-events-none -z-5 overflow-hidden">
			<div class="float-element absolute top-[20%] right-[10%] w-2 h-2 rounded-full bg-ns-gold/20"></div>
			<div class="float-element absolute top-[40%] left-[5%] w-1.5 h-1.5 rounded-full bg-ns-red/15"></div>
			<div class="float-element absolute top-[60%] right-[20%] w-1 h-1 rounded-full bg-ns-gold/25"></div>
			<div class="float-element absolute top-[80%] left-[15%] w-2 h-2 rounded-full bg-ns-red/10"></div>
		</div>

		<div class="relative z-20">
			<slot />
		</div>

	</body>
</html>